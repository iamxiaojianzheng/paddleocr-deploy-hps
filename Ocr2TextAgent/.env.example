# LLM Configuration
# Supports any OpenAI-compatible API (OpenAI, DeepSeek, Ollama, etc.)
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# OCR Services Configuration
# These are the default ports according to the documentation.
# The user needs to ensure they are correct when running the services.
PP_OCRV5_URL=http://localhost:8080/ocr
PP_STRUCTUREV3_URL=http://localhost:8081/layout-parsing
PADDLEOCR_VL_URL=http://localhost:8080/layout-parsing

# Agent Server Configuration
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
